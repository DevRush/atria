# Copy to .env.local and fill in. None are required for the current demo
# (generate / repair / publish / on-call all run without them).

# Isolated solver service (FastAPI). Defaults to localhost:8000 if unset.
SOLVER_URL=http://localhost:8000

# SQLite location. Defaults to file:./prisma/dev.db if unset.
# DATABASE_URL=file:./prisma/dev.db

# Anthropic API key — only needed once the AI rule-capture flow (upload Excel →
# Claude drafts rule cards) is wired in. Not used by the current demo.
# ANTHROPIC_API_KEY=sk-ant-...
